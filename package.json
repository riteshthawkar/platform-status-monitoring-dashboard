{
  "name": "platform-status-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "backup:db": "bash src/scripts/backup-database.sh",
    "restore:db": "bash src/scripts/restore-database.sh",
    "check": "tsx src/scripts/cron-checker.ts",
    "check:once": "tsx src/scripts/cron-checker.ts",
    "monitoring:conformance": "tsx src/scripts/monitoring-conformance.ts",
    "add-service": "tsx src/scripts/add-service.ts",
    "setup:cron": "bash src/scripts/setup-cron.sh",
