# ============================================================
# Platform Status Dashboard — Environment Variables
# Copy this to .env.local and fill in values
# ============================================================

# ─── Background Check Runner ───────────────────────────────
# Choose ONE production runner:
#   - scheduler: in-process runner inside the Next.js app (recommended)
#   - cron: external crontab running src/scripts/cron-checker.ts
CHECK_RUNNER_MODE=scheduler

# ─── Database Storage ──────────────────────────────────────
# For a single droplet, point SQLite at an absolute path outside the repo
# so redeploys and git pulls do not affect the database file.
# Example:
# DATABASE_PATH=/home/dashuser/status-dashboard-data/status.db

# Nightly SQLite backups for a single droplet
# Example:
# DATABASE_BACKUP_DIR=/home/dashuser/status-dashboard-backups
DATABASE_BACKUP_RETENTION_DAYS=14
# Daily at 02:15 server time
DATABASE_BACKUP_CRON=15 2 * * *

# Optional override for local development
# ENABLE_SCHEDULER=true

# ─── Slack Alerts (optional) ────────────────────────────────
# Get webhook URL from: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── Email Alerts (SMTP — optional) ────────────────────────
# Works with Gmail, Outlook, SendGrid, AWS SES, etc.
#
# Gmail setup:
#   1. Enable 2FA → https://myaccount.google.com/security
#   2. Create App Password → https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password as SMTP_PASS
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
# ALERT_EMAIL_FROM=your-email@gmail.com
# ALERT_EMAIL_TO=admin@example.com,devops@example.com

# ─── Alert Settings ────────────────────────────────────────
# Minutes between repeated alerts for the same service
ALERT_COOLDOWN_MINUTES=10

# Ongoing failure reminders (email only)
# Real-world default:
#   - send the first follow-up after 15 min for hard outages
#   - send the first follow-up after 30 min for degraded services
#   - repeat every 60 min until recovery
ALERT_REMINDER_ENABLED=true
ALERT_REMINDER_DOWN_MINUTES=15
ALERT_REMINDER_DEGRADED_MINUTES=30
ALERT_REMINDER_REPEAT_MINUTES=60

# Prolonged-incident escalation (email only)
# Real-world default for startup production operations:
#   - escalate hard outages after 30 min unresolved
#   - escalate degraded services after 120 min unresolved
#   - repeat every 180 min until recovery
# ALERT_ESCALATION_EMAIL_TO=founders@example.com,ops-lead@example.com
ALERT_ESCALATION_ENABLED=true
ALERT_ESCALATION_DOWN_MINUTES=30
ALERT_ESCALATION_DEGRADED_MINUTES=120
ALERT_ESCALATION_REPEAT_MINUTES=180

# ─── API Authentication (optional) ────────────────────────
# External automation can use an API key against /api routes.
# API_KEY=your-secret-api-key-here

# ─── Dashboard Authentication (strongly recommended in production) ───────
# Protects the browser dashboard and also authorizes API mutations via
# standard HTTP Basic Auth.
# DASHBOARD_USERNAME=ops
# DASHBOARD_PASSWORD=replace-with-a-long-random-password

# ─── Transport Security ─────────────────────────────────────
# In production, non-local dashboard requests redirect to HTTPS by default.
# Set this to false only if TLS is terminated elsewhere and the app does not
# receive x-forwarded-proto=https.
# ENFORCE_HTTPS=true

# Fail closed in production unless dashboard credentials are configured.
# Set this to true only for trusted private-network bring-up scenarios.
# ALLOW_INSECURE_DASHBOARD=false
